{
  "name": "git",
  "version": "0.1.0",
  "description": "Git status, stage/unstage, commit graph",
  "main": "./reef-git",
  "activation_events": [
    "onPanel:git.status",
    "onPanel:git.graph",
    "onPanel:git.commitDetail"
  ],
  "contributes": {
    "panels": [
      { "id": "git.status",       "title": "Git",    "slot": "sidebar", "icon": "⎇" },
      { "id": "git.graph",        "title": "Graph",  "slot": "sidebar", "icon": "⑂" },
      { "id": "git.commitDetail", "title": "Commit", "slot": "editor" }
    ],
    "keybindings": [
      { "key": "s", "command": "git.stage",   "when": "panel == git.status", "description": "暂存当前选中文件" },
      { "key": "u", "command": "git.unstage", "when": "panel == git.status", "description": "取消暂存当前选中文件" },
      { "key": "d", "command": "git.discard", "when": "panel == git.status", "description": "还原当前选中文件（弹出确认）" },
      { "key": "r", "command": "git.refresh", "when": "panel == git.status", "description": "刷新 Git 状态" },
      { "key": "j", "command": "git.graph.next",  "when": "panel == git.graph", "description": "Graph：下一个 commit" },
      { "key": "k", "command": "git.graph.prev",  "when": "panel == git.graph", "description": "Graph：上一个 commit" }
    ],
    "commands": [
      { "id": "git.stage",          "title": "暂存文件" },
      { "id": "git.unstage",        "title": "取消暂存" },
      { "id": "git.discard",        "title": "还原文件（工作区）" },
      { "id": "git.discardConfirm", "title": "确认还原" },
      { "id": "git.discardCancel",  "title": "取消还原" },
      { "id": "git.refresh",        "title": "刷新 Git 状态" },
      { "id": "git.selectFile",     "title": "选择文件" },
      { "id": "git.toggleStaged",   "title": "折叠/展开暂存区" },
      { "id": "git.toggleUnstaged", "title": "折叠/展开更改区" },
      { "id": "git.graph.next",     "title": "下一个 commit" },
      { "id": "git.graph.prev",     "title": "上一个 commit" },
      { "id": "git.selectCommit",   "title": "选中 commit" },
      { "id": "git.selectCommitFile", "title": "查看 commit 内文件 diff" },
      { "id": "git.graph.refresh",  "title": "刷新 commit 图" }
    ]
  }
}
