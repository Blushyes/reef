{
  "name": "git",
  "version": "0.1.0",
  "description": "Git status, stage/unstage, commit graph",
  "main": "./reef-git",
  "activation_events": [
    "onPanel:git.status",
    "onPanel:git.graph",
    "onPanel:git.commitDetail"
  ],
  "contributes": {
    "panels": [
      { "id": "git.status",       "title": "Git",    "slot": "sidebar", "icon": "⎇" },
      { "id": "git.graph",        "title": "Graph",  "slot": "sidebar", "icon": "⑂" },
      { "id": "git.commitDetail", "title": "Commit", "slot": "editor" }
    ],
    "keybindings": [
      { "key": "s", "command": "git.stage",   "when": "panel == git.status" },
      { "key": "u", "command": "git.unstage", "when": "panel == git.status" },
      { "key": "r", "command": "git.refresh", "when": "panel == git.status" },
      { "key": "j", "command": "git.graph.next",  "when": "panel == git.graph" },
      { "key": "k", "command": "git.graph.prev",  "when": "panel == git.graph" }
    ],
    "commands": [
      { "id": "git.stage",         "title": "暂存文件" },
      { "id": "git.unstage",       "title": "取消暂存" },
      { "id": "git.refresh",       "title": "刷新 Git 状态" },
      { "id": "git.selectFile",    "title": "选择文件" },
      { "id": "git.toggleStaged",  "title": "折叠/展开暂存区" },
      { "id": "git.toggleUnstaged","title": "折叠/展开更改区" },
      { "id": "git.graph.next",    "title": "下一个 commit" },
      { "id": "git.graph.prev",    "title": "上一个 commit" },
      { "id": "git.selectCommit",  "title": "选中 commit" },
      { "id": "git.selectCommitFile", "title": "查看 commit 内文件 diff" },
      { "id": "git.graph.refresh", "title": "刷新 commit 图" }
    ]
  }
}
